{
  "ConnectionStrings": {
    "OrdersDb": "Host=localhost;Port=5432;Database=orders;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Properties": {
      "Application": "OrderService"
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "order-platform.exchange",
    "PublisherConfirmTimeoutSeconds": 5,
    "ConsumersEnabled": true
  },
  "Outbox": {
    "Enabled": true,
    "BatchSize": 25,
    "PollIntervalMilliseconds": 1000
  }
}
