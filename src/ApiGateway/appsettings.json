{
  "ServiceUrls": {
    "OrderService": "http://localhost:8081",
    "InventoryService": "http://localhost:8082",
    "PaymentService": "http://localhost:8083",
    "NotificationService": "http://localhost:8084",
    "ReportingService": "http://localhost:8085"
  },
  "GatewayAuth": {
    "ApiKeyHeaderName": "X-Demo-Api-Key",
    "ApiKey": "local-dev-key",
    "BearerToken": "local-dev-token"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Properties": {
      "Application": "ApiGateway"
    }
  },
  "AllowedHosts": "*"
}
